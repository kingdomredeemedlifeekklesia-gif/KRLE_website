generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model UploadedVideo {
  id          String   @id @default(cuid())
  title       String
  description String
  filename    String
  url         String
  uploadedAt  DateTime @default(now())
}

model ContactMessage {
  id         String   @id @default(cuid())
  name       String
  email      String
  whatsapp   String?
  message    String
  status     String   @default("unread") // unread | read | replied
  adminReply String?
  adminNote  String?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
}

model CommunityMember {
  id             String   @id @default(cuid())
  name           String
  whatsappNumber String
  joinedAt       DateTime @default(now())
}

model GalleryImage {
  id          String   @id @default(cuid())
  title       String
  description String?
  filename    String
  url         String
  category    String   // programs, services, events, etc.
  uploadedAt  DateTime @default(now())
}

model PaymentTransaction {
  id        String   @id @default(cuid())
  donor     String?
  email     String?
  amount    Float
  currency  String   @default("GHS")
  purpose   String
  type      String   // donation | expense
  status    String   @default("Completed")
  provider  String?
  note      String?
  details   String?
  createdAt DateTime @default(now())
}

model RecurringSubscription {
  id                String   @id @default(cuid())
  donor             String?
  email             String?
  phone             String?
  authorizationCode String   @unique
  customerCode      String?
  cardBrand         String?
  last4             String?
  expMonth          Int?
  expYear           Int?
  amount            Float
  currency          String   @default("GHS")
  purpose           String
  active            Boolean  @default(true)
  nextChargeAt      DateTime?
  lastChargedAt     DateTime?
  lastChargeStatus  String?
  note              String?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
}

model Record {
  id        String   @id @default(cuid())
  type      String   @default("Member")
  name      String
  email     String
  joinedAt  DateTime @default(now())
  status    String   @default("Active")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}
